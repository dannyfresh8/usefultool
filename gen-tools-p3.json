{
  "heart-rate": {
    "title": "Heart Rate Zone Calculator",
    "desc": "Calculate your target heart rate zones for exercise. Find your maximum heart rate, fat-burn zone, cardio zone, and peak zone for workouts.",
    "form": "<div style=display:grid;gap:8px;><label>Age:<br><input type=number id=hrAge value=30 min=1 max=120 style=width:100%;></label><label>Resting Heart Rate (bpm):<br><input type=number id=hrRest value=65 min=30 max=120 style=width:100%;></label><label>Activity Level:<br><select id=hrLevel style=width:100%;><option value=sedentary>Sedentary</option><option value=moderate selected>Moderate</option><option value=active>Active</option><option value=athlete>Athlete</option></select></label></div><button onclick=calcHRZones()>Calculate Zones</button><div id=hrResult></div><script>function calcHRZones(){var age=+hrAge.value,rest=+hrRest.value;var maxHR=208-0.7*age;var reserve=maxHR-rest;var z1='50-60%',z2='60-70%',z3='70-80%',z4='80-90%',z5='90-100%';var r1=Math.round(reserve*0.5+rest)+'-'+Math.round(reserve*0.6+rest);var r2=Math.round(reserve*0.6+rest)+'-'+Math.round(reserve*0.7+rest);var r3=Math.round(reserve*0.7+rest)+'-'+Math.round(reserve*0.8+rest);var r4=Math.round(reserve*0.8+rest)+'-'+Math.round(reserve*0.9+rest);var r5=Math.round(reserve*0.9+rest)+'-'+Math.round(reserve*1.0+rest);hrResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>Heart Rate Zones</b><hr><div>Max HR: <b>'+Math.round(maxHR)+' bpm</b></div><div>HR Reserve: <b>'+Math.round(reserve)+' bpm</b></div><table style=width:100%;margin-top:8px;border-collapse:collapse;><tr style=background:#fef3c7;><td><b>Z1 Fat Burn</b></td><td>'+r1+' bpm</td><td>'+z1+'</td></tr><tr style=background:#f0f9ff;><td><b>Z2 Cardio</b></td><td>'+r2+' bpm</td><td>'+z2+'</td></tr><tr style=background:#f0fdf4;><td><b>Z3 Aerobic</b></td><td>'+r3+' bpm</td><td>'+z3+'</td></tr><tr style=background:#fef2f2;><td><b>Z4 Anaerobic</b></td><td>'+r4+' bpm</td><td>'+z4+'</td></tr><tr style=background:#f5f3ff;><td><b>Z5 Max Effort</b></td><td>'+r5+' bpm</td><td>'+z5+'</td></tr></table></div>';}</script>"
  },
  "macro-calculator": {
    "title": "Macro Calculator (Protein/Fat/Carbs)",
    "desc": "Calculate your daily macronutrient needs based on your goal. Get protein, fat, and carb targets for weight loss, maintenance, or muscle gain.",
    "form": "<div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Weight (kg):<br><input type=number id=mw value=75 step=1></label><label>Height (cm):<br><input type=number id=mh value=175 step=1></label><label>Age:<br><input type=number id=ma value=30 step=1></label><label>Gender:<br><select id=mg><option value=male>Male</option><option value=female>Female</option></select></label><label style=grid-column:span 2;>Goal:<br><select id=mgoal style=width:100%;><option value=loss>Weight Loss</option><option value=maintain selected>Maintain Weight</option><option value=gain>Muscle Gain</option></select></label></div><button onclick=calcMacros()>Calculate Macros</button><div id=macroResult></div><script>function calcMacros(){var w=+mw.value,h=+mh.value,a=+ma.value,g=mg.value,goal=mgoal.value;var bmr=g=='male'?10*w+6.25*h-5*a+5:10*w+6.25*h-5*a-161;var adj=goal=='loss'?0.8:goal=='gain'?1.15:1;var tdee=bmr*adj*1.55;var p=w*2.2,c,f;if(goal=='loss'){c=tdee*0.3/9;f=tdee*0.3/9}else if(goal=='gain'){c=tdee*0.5/4;f=tdee*0.2/9}else{c=tdee*0.45/4;f=tdee*0.2/9}macroResult.innerHTML='<div style=background:#f0fdf4;padding:16px;border-radius:8px;margin-top:12px;><b>Daily Macros</b><hr><div>TDEE: <b>'+Math.round(tdee)+' kcal</b></div><div style=margin-top:8px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;text-align:center;><div style=background:#dbeafe;padding:12px;border-radius:8px;><div style=font-size:28px;font-weight:700;color:#2563eb;>'+Math.round(p)+'g</div><div style=font-size:13px;>Protein</div></div><div style=background:#fef3c7;padding:12px;border-radius:8px;><div style=font-size:28px;font-weight:700;color:#d97706;>'+Math.round(f)+'g</div><div style=font-size:13px;>Fat</div></div><div style=background:#fce7f3;padding:12px;border-radius:8px;><div style=font-size:28px;font-weight:700;color:#db2777;>'+Math.round(c)+'g</div><div style=font-size:13px;>Carbs</div></div></div></div>';}</script>"
  },
  "ideal-weight": {
    "title": "Ideal Weight Calculator",
    "desc": "Calculate your ideal body weight using multiple formulas. Compare Devine, Robinson, Miller, and Hamwi methods for a healthy weight range.",
    "form": "<div style=display:grid;gap:8px;><label>Gender:<br><select id=iwg style=width:100%;><option value=male>Male</option><option value=female>Female</option></select></label><label>Height (cm):<br><input type=number id=iwh value=175 step=1 style=width:100%;></label></div><button onclick=calcIdealWeight()>Calculate</button><div id=iwResult></div><script>function calcIdealWeight(){var g=iwg.value,h=+iwh.value;var inches=h/2.54,ft5=inches-60;var devine=0,r=0,m=0,ham=0;if(g=='male'){devine=50+2.3*ft5;r=52+1.9*ft5;m=56.2+1.41*ft5;ham=48+2.7*ft5}else{devine=45.5+2.3*ft5;r=49+1.7*ft5;m=53.1+1.36*ft5;ham=45.5+2.2*ft5}var avg=(devine+r+m+ham)/4;var low=avg*0.9,high=avg*1.1;iwResult.innerHTML='<div style=background:#f0fdf4;padding:16px;border-radius:8px;margin-top:12px;><b>Ideal Weight Estimates</b><hr><table style=width:100%;border-collapse:collapse;><tr><td>Devine:</td><td>'+devine.toFixed(1)+' kg</td></tr><tr><td>Robinson:</td><td>'+r.toFixed(1)+' kg</td></tr><tr><td>Miller:</td><td>'+m.toFixed(1)+' kg</td></tr><tr><td>Hamwi:</td><td>'+ham.toFixed(1)+' kg</td></tr></table><hr><div style=font-size:20px;font-weight:600;color:#2563eb;>Average: '+avg.toFixed(1)+' kg</div><div style=color:#6b7280;>Healthy range: '+low.toFixed(1)+' - '+high.toFixed(1)+' kg</div></div>';}</script>"
  },
  "calorie-calculator": {
    "title": "Calorie Calculator (BMR & TDEE)",
    "desc": "Calculate your daily calorie needs using BMR and TDEE. Get maintenance, weight loss, and muscle gain calorie targets based on your activity level.",
    "form": "<div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Weight (kg):<br><input type=number id=ccw value=75 step=1></label><label>Height (cm):<br><input type=number id=cch value=175 step=1></label><label>Age:<br><input type=number id=cca value=30 step=1></label><label>Gender:<br><select id=ccg><option value=male>Male</option><option value=female>Female</option></select></label><label style=grid-column:span 2;>Activity:<br><select id=ccact style=width:100%;><option value=1.2>Sedentary</option><option value=1.375>Light (1-3d/wk)</option><option value=1.55 selected>Moderate (3-5d/wk)</option><option value=1.725>Active (6-7d/wk)</option><option value=1.9>Very Active</option></select></label></div><button onclick=calcCalories()>Calculate Calories</button><div id=ccResult></div><script>function calcCalories(){var w=+ccw.value,h=+cch.value,a=+cca.value,g=ccg.value,act=+ccact.value;var bmr=g=='male'?10*w+6.25*h-5*a+5:10*w+6.25*h-5*a-161;var tdee=bmr*act;ccResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>Calorie Breakdown</b><hr><div>BMR: <b>'+Math.round(bmr)+' kcal</b></div><div>TDEE (Maintain): <b style=font-size:20px;color:#2563eb;>'+Math.round(tdee)+' kcal</b></div><hr><div>Weight Loss (-20%): <b style=color:#059669;>'+Math.round(tdee*0.8)+' kcal</b></div><div>Slow Loss (-10%): <b>'+Math.round(tdee*0.9)+' kcal</b></div><div>Muscle Gain (+15%): <b style=color:#dc2626;>'+Math.round(tdee*1.15)+' kcal</b></div></div>';}</script>"
  },
  "bmr-calculator": {
    "title": "BMR Calculator (Basal Metabolic Rate)",
    "desc": "Calculate your Basal Metabolic Rate using the Mifflin-St Jeor equation. Find out how many calories your body burns at rest each day.",
    "form": "<div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Weight (kg):<br><input type=number id=brw value=75 step=1></label><label>Height (cm):<br><input type=number id=brh value=175 step=1></label><label>Age:<br><input type=number id=bra value=30 step=1></label><label>Gender:<br><select id=brg><option value=male>Male</option><option value=female>Female</option></select></label></div><button onclick=calcBMR()>Calculate BMR</button><div id=brResult></div><script>function calcBMR(){var w=+brw.value,h=+brh.value,a=+bra.value,g=brg.value;var bmr=g=='male'?10*w+6.25*h-5*a+5:10*w+6.25*h-5*a-161;brResult.innerHTML='<div style=background:#eff6ff;padding:16px;border-radius:8px;margin-top:12px;text-align:center;><b>Basal Metabolic Rate</b><hr><div style=font-size:48px;font-weight:700;color:#2563eb;>'+Math.round(bmr)+'</div><div style=font-size:14px;color:#6b7280;>calories/day at rest</div><hr><div style=text-align:left;>Est. daily needs:<br>Sedentary: <b>'+Math.round(bmr*1.2)+'</b> kcal<br>Moderate: <b>'+Math.round(bmr*1.55)+'</b> kcal<br>Active: <b>'+Math.round(bmr*1.725)+'</b> kcal</div></div>';}</script>"
  },
  "body-fat": {
    "title": "Body Fat Calculator (US Navy Method)",
    "desc": "Estimate your body fat percentage using the US Navy circumference method. Uses height, neck, and waist measurements for a reliable estimate.",
    "form": "<div style=display:grid;gap:8px;><label>Gender:<br><select id=bfg style=width:100%;><option value=male>Male</option><option value=female>Female</option></select></label><label>Height (cm):<br><input type=number id=bfh value=175 step=1 style=width:100%;></label><label>Neck Circumference (cm):<br><input type=number id=bfn value=38 step=0.5 style=width:100%;></label><label>Waist Circumference (cm):<br><input type=number id=bfw value=82 step=0.5 style=width:100%;></label></div><button onclick=calcBodyFat()>Calculate</button><div id=bfResult></div><script>function calcBodyFat(){var g=bfg.value,h=+bfh.value,n=+bfn.value,w=+bfw.value;if(g=='female'){var hip=+document.getElementById('bfhip').value;var p=86.01*Math.log10(w-n-hip)-70.041*Math.log10(h)+36.76}else{p=86.01*Math.log10(w-n)-70.041*Math.log10(h)+36.76}var bf=Math.max(3,Math.min(60,p.toFixed(1)));var level=bf<10?'Athletic':bf<20?'Fit':bf<25?'Average':bf<30?'Overweight':'Obese';var color=bf<20?'#059669':bf<25?'#d97706':'#dc2626';bfResult.innerHTML='<div style=background:#f0fdf4;padding:16px;border-radius:8px;margin-top:12px;text-align:center;><b>Body Fat Estimate</b><hr><div style=font-size:48px;font-weight:700;color:'+color+';>'+bf+'%</div><div style=color:#6b7280;>Category: <b>'+level+'</b></div><hr style=margin:8px 0;><div style='+(!g.includes('female')?'display:none':'')+' id=bfhipRow><label style=display:block;>Hip (cm):<br><input type=number id=bfhip value=90 step=0.5 style=width:100px;></label></div></div>';}</script>"
  }
}
