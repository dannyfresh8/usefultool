{
  "plagiarism-checker": {
    "title": "Plagiarism Checker (Text Similarity)",
    "desc": "Quickly check your text against common phrases and get a similarity score. Free plagiarism detection tool for students and writers.",
    "form": "<div style=display:grid;gap:8px;><label>Paste your text:<br><textarea id=textRow rows=4 style=width:100%;font-family:monospace;font-size:13px;>This article explores the impact of social media on mental health and well-being.</textarea></label><label>Check against phrase:<br><input type=text id=phrase value='social media mental health' style=width:100%;></label></div><button onclick=checkPlag()>Check Similarity</button><div id=plagResult></div><script>function checkPlag(){const t=textRow.value.toLowerCase(),p=phrase.value.toLowerCase();const words=t.split(/\\s+/).filter(function(w){return w.length>3}).length;const pw=p.split(/\\s+/).filter(function(w){return w.length>2});let matches=0;pw.forEach(function(w){if(t.includes(w))matches++});const score=pw.length?(matches/pw.length)*100:0;const level=score>60?'High':score>30?'Medium':'Low';const color=score>60?'#dc2626':score>30?'#d97706':'#059669';plagResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>Similarity Results</b><hr><div>Words checked: '+words+'</div><div>Matches: '+matches+'/'+pw.length+'</div><div style=font-weight:600;font-size:18px;color:'+color+';>Similarity: '+score.toFixed(0)+'% ('+level+')</div><div style=margin-top:8px;padding:8px;background:#fef3c7;border-radius:4px;>Basic similarity check. For professional detection, use Turnitin or Grammarly.</div></div>';}</script>"
  },
  "citation-generator": {
    "title": "Citation Generator (APA/MLA)",
    "desc": "Generate citations in APA and MLA format for books, websites, and journal articles. Perfect for student research papers and academic writing.",
    "form": "<div style=display:grid;gap:8px;><label>Source Type:<br><select id=sourcetype style=width:100%;><option value=book>Book</option><option value=website>Website</option><option value=journal>Journal Article</option></select></label><label>Author (Last, First):<br><input type=text id=author value='Smith, John' style=width:100%;></label><label>Title:<br><input type=text id=citTitle value='The Art of Research' style=width:100%;></label><label>Year:<br><input type=number id=year value=2024 style=width:100%;></label></div><button onclick=genCitation()>Generate Citation</button><div id=citResult></div><script>function genCitation(){var st=sourcetype.value,au=author.value,ti=citTitle.value,yr=year.value;var apa='',mla='';if(st=='book'){var pub='Publisher Name';apa=au+'. ('+yr+'). <i>'+ti+'</i>. '+pub+'.';mla=au+'. <i>'+ti+'</i>. '+pub+', '+yr+'.'}else if(st=='website'){apa=au+'. ('+yr+'). <i>'+ti+'</i>. Website Name.';mla=au+'. '+ti+'. <i>Website Name</i>, '+yr+'.'}else{var j='Journal Name';apa=au+'. ('+yr+'). '+ti+'. <i>'+j+'</i>, 12(3), 45-67.';mla=au+'. '+ti+'. <i>'+j+'</i>, vol.12, no.3, pp.45-67.'}citResult.innerHTML='<div style=background:white;padding:16px;border-radius:8px;margin-top:12px;><b style=color:#2563eb;>APA:</b><div style=background:#f8fafc;padding:12px;border-radius:4px;margin:8px 0;font-size:14px;>'+apa+'</div><b style=color:#059669;>MLA:</b><div style=background:#f8fafc;padding:12px;border-radius:4px;margin:8px 0;font-size:14px;>'+mla+'</div></div>';}</script>"
  },
  "study-timer": {
    "title": "Study Timer with Focus Sessions",
    "desc": "Track your study sessions with a Pomodoro-style timer. Work in focused 25-minute blocks, take breaks, and track total study time.",
    "form": "<div style=text-align:center;><div id=stTimer style=font-size:64px;font-weight:700;font-family:monospace;color:#2563eb;margin:16px 0;>25:00</div><div style=display:flex;gap:8px;justify-content:center;flex-wrap:wrap;><button onclick=startStudy() style=padding:8px 24px;border:none;background:#2563eb;color:white;border-radius:8px;cursor:pointer;>Start</button><button onclick=pauseStudy() style=padding:8px 24px;border:none;background:#6b7280;color:white;border-radius:8px;cursor:pointer;>Pause</button><button onclick=resetStudy() style=padding:8px 24px;border:none;background:#dc2626;color:white;border-radius:8px;cursor:pointer;>Reset</button></div><div id=studyStats style=margin-top:12px;color:#6b7280;>Sessions: 0 | Total: 0m</div></div><script>var stInt,sTime=1500,stPaused=false,stSess=0,stTot=0;function updST(){var m=Math.floor(sTime/60),s=sTime%60;stTimer.textContent=(m<10?'0':'')+m+':'+(s<10?'0':'')+s;}function startStudy(){if(stInt)return;stInt=setInterval(function(){if(!stPaused){sTime--;stTot++;if(sTime<=0){clearInterval(stInt);stInt=null;stSess++;studyStats.textContent='Sessions: '+stSess+' | Total: '+Math.floor(stTot/60)+'m';alert('Complete! Take a 5-min break.');sTime=300;updST()}}},1000);updST();}function pauseStudy(){stPaused=!stPaused;}function resetStudy(){clearInterval(stInt);stInt=null;sTime=1500;stPaused=false;updST();}</script>"
  },
  "flashcard-maker": {
    "title": "Online Flashcard Maker",
    "desc": "Create and study flashcards online. Add questions and answers, reveal them one by one, and test your knowledge. Perfect for exam prep.",
    "form": "<div id=flashArea><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;><textarea id=q1 rows=2 placeholder='Question 1' style=font-size:13px;>What is HTML?</textarea><textarea id=a1 rows=2 placeholder='Answer 1' style=font-size:13px;>HyperText Markup Language</textarea></div><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;><textarea id=q2 rows=2 placeholder='Question 2' style=font-size:13px;>What is CSS?</textarea><textarea id=a2 rows=2 placeholder='Answer 2' style=font-size:13px;>Cascading Style Sheets</textarea></div><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;><textarea id=q3 rows=2 placeholder='Question 3' style=font-size:13px;>What is JS?</textarea><textarea id=a3 rows=2 placeholder='Answer 3' style=font-size:13px;>JavaScript programming language</textarea></div></div><button onclick=startFlashcards()>Study Flashcards</button><div id=flashResult></div><script>function startFlashcards(){var cards=[];for(var i=1;i<=3;i++){var q=document.getElementById('q'+i).value.trim(),a=document.getElementById('a'+i).value.trim();if(q&&a)cards.push({q:q,a:a})}if(cards.length==0){flashResult.innerHTML='<div style=color:#dc2626;>Add question and answer pairs.</div>';return}var idx=0,show=false;function showCard(){if(idx>=cards.length){flashResult.innerHTML='<div style=background:#f0fdf4;padding:20px;border-radius:8px;text-align:center;>All '+cards.length+' cards studied!</div>';return}var c=cards[idx];flashResult.innerHTML='<div style=background:#f8fafc;padding:20px;border-radius:8px;text-align:center;cursor:pointer;onclick=revealA();>'+(show?'<b>Answer:</b><br><div style=font-size:24px;color:#059669;>'+c.a+'</div><br><button onclick=nextF() style=padding:8px 24px;>Next</button>':'<b>Question:</b><br><div style=font-size:24px;color:#2563eb;>'+c.q+'</div><br><span style=font-size:13px;color:#6b7280;>Click to reveal</span>')+'</div>';}window.revealA=function(){show=true;showCard()};window.nextF=function(){idx++;show=false;showCard()};showCard();}</script>"
  },
  "gpa-semester": {
    "title": "Semester GPA Calculator",
    "desc": "Calculate your semester GPA from course grades and credit hours. Add multiple courses and instantly see your cumulative GPA.",
    "form": "<div style=display:grid;gap:8px;><div style=display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;font-weight:600;color:#6b7280;><span>Course</span><span>Grade</span><span>Credits</span></div><div style=display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;><input type=text id=gc1 value='Math 101' style=padding:6px;><select id=gg1 style=padding:6px;><option value=4>A (4.0)</option><option value=3.7>A- (3.7)</option><option value=3.3>B+ (3.3)</option><option value=3 selected>B (3.0)</option><option value=2.7>B- (2.7)</option><option value=2.3>C+ (2.3)</option><option value=2>C (2.0)</option><option value=1.7>C- (1.7)</option><option value=1>D (1.0)</option><option value=0>F (0.0)</option></select><input type=number id=gh1 value=4 min=1 max=6 style=padding:6px;width:60px;></div><div style=display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;><input type=text id=gc2 value='Eng 101' style=padding:6px;><select id=gg2 style=padding:6px;><option value=4>A (4.0)</option><option value=3.7>A- (3.7)</option><option value=3.3 selected>B+ (3.3)</option><option value=3>B (3.0)</option><option value=2.7>B- (2.7)</option><option value=2.3>C+ (2.3)</option><option value=2>C (2.0)</option><option value=1.7>C- (1.7)</option><option value=1>D (1.0)</option><option value=0>F (0.0)</option></select><input type=number id=gh2 value=3 min=1 max=6 style=padding:6px;width:60px;></div><div style=display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;><input type=text id=gc3 value='Science 101' style=padding:6px;><select id=gg3 style=padding:6px;><option value=4>A (4.0)</option><option value=3.7 selected>A- (3.7)</option><option value=3.3>B+ (3.3)</option><option value=3>B (3.0)</option><option value=2.7>B- (2.7)</option><option value=2.3>C+ (2.3)</option><option value=2>C (2.0)</option><option value=1.7>C- (1.7)</option><option value=1>D (1.0)</option><option value=0>F (0.0)</option></select><input type=number id=gh3 value=4 min=1 max=6 style=padding:6px;width:60px;></div></div><button onclick=calcSemGPA()>Calculate GPA</button><div id=gpaResult></div><script>function calcSemGPA(){let tp=0,th=0;for(var i=1;i<=3;i++){var g=+document.getElementById('gg'+i).value,h=+document.getElementById('gh'+i).value;if(h>0){tp+=g*h;th+=h}}var g=th>0?tp/th:0;var c=g>=3.5?'#059669':g>=2.5?'#d97706':'#dc2626';gpaResult.innerHTML='<div style=background:#f0fdf4;padding:16px;border-radius:8px;margin-top:12px;><b>Semester GPA</b><hr><div style=font-size:48px;font-weight:700;color:'+c+';text-align:center;>'+g.toFixed(2)+'</div><div style=text-align:center;color:#6b7280;>Hours: '+th+' | Points: '+tp.toFixed(0)+'</div></div>';}</script>"
  },
  "volume-calculator": {
    "title": "Volume Calculator (3D Shapes)",
    "desc": "Calculate the volume of cubes, spheres, cylinders, cones, and rectangular prisms. Get precise results in cubic units instantly.",
    "form": "<div style=display:grid;gap:8px;><label>Shape:<br><select id=shape onchange=updateVolFields() style=width:100%;><option value=cube>Cube</option><option value=sphere>Sphere</option><option value=cylinder>Cylinder</option><option value=cone>Cone</option><option value=rect>Rectangular Prism</option></select></label><div id=volFields><label>Side Length:<br><input type=number id=v1 value=5 step=0.5></label></div></div><button onclick=calcVolume()>Calculate Volume</button><div id=volResult></div><script>function updateVolFields(){var s=shape.value;if(s=='cube')volFields.innerHTML='<label>Side:<br><input type=number id=v1 value=5 step=0.5></label>';else if(s=='sphere')volFields.innerHTML='<label>Radius:<br><input type=number id=v1 value=5 step=0.5></label>';else if(s=='cylinder')volFields.innerHTML='<label>Radius:<br><input type=number id=v1 value=5 step=0.5></label><label>Height:<br><input type=number id=v2 value=10 step=0.5></label>';else if(s=='cone')volFields.innerHTML='<label>Radius:<br><input type=number id=v1 value=5 step=0.5></label><label>Height:<br><input type=number id=v2 value=10 step=0.5></label>';else volFields.innerHTML='<label>Length:<br><input type=number id=v1 value=5 step=0.5></label><label>Width:<br><input type=number id=v2 value=5 step=0.5></label><label>Height:<br><input type=number id=v3 value=5 step=0.5></label>';}function calcVolume(){var s=shape.value,v;if(s=='cube')v=+v1.value**3;else if(s=='sphere')v=(4/3)*Math.PI*+v1.value**3;else if(s=='cylinder')v=Math.PI*+v1.value**2*+v2.value;else if(s=='cone')v=(1/3)*Math.PI*+v1.value**2*+v2.value;else v=+v1.value*+v2.value*+v3.value;var n=s.charAt(0).toUpperCase()+s.slice(1);volResult.innerHTML='<div style=background:#f0f9ff;padding:16px;border-radius:8px;margin-top:12px;><b>Volume of '+n+'</b><hr><div style=font-size:36px;font-weight:700;color:#2563eb;text-align:center;>'+v.toFixed(2)+'</div><div style=text-align:center;color:#6b7280;>cubic units</div></div>';}</script>"
  },
  "density-calculator": {
    "title": "Density, Mass & Volume Calculator",
    "desc": "Calculate density, mass, or volume using the density formula. Enter any two values to find the third. Works with any unit system.",
    "form": "<div style=display:grid;gap:8px;><label>Calculate:<br><select id=dmode style=width:100%;><option value=density>Density (mass/volume)</option><option value=mass>Mass (density x volume)</option><option value=volume>Volume (mass/density)</option></select></label><label>Mass:<br><input type=number id=dmass value=100 step=1></label><label>Volume:<br><input type=number id=dvol value=25 step=0.5></label><label>Density:<br><input type=number id=ddens value=4 step=0.1></label></div><button onclick=calcDensity()>Calculate</button><div id=denResult></div><script>function calcDensity(){var m=+dmass.value,v=+dvol.value,d=+ddens.value,mode=dmode.value,r;if(mode=='density'){r=v>0?m/v:0;label='Density'}else if(mode=='mass'){r=d*v;label='Mass'}else{r=d>0?m/d:0;label='Volume'}denResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>'+label+'</b><hr><div style=font-size:36px;font-weight:700;color:#059669;text-align:center;>'+r.toFixed(4)+'</div></div>';}</script>"
  },
  "area-calculator": {
    "title": "Area Calculator (2D Shapes)",
    "desc": "Calculate the area of squares, rectangles, circles, triangles, parallelograms, and trapezoids. Quick geometry formulas at your fingertips.",
    "form": "<div style=display:grid;gap:8px;><label>Shape:<br><select id=ashape onchange=updateAreaFields() style=width:100%;><option value=square>Square</option><option value=rect>Rectangle</option><option value=circle>Circle</option><option value=triangle>Triangle</option><option value=para>Parallelogram</option><option value=trap>Trapezoid</option></select></label><div id=areaFields><label>Side:<br><input type=number id=a1 value=5 step=0.5></label></div></div><button onclick=calcArea()>Calculate Area</button><div id=areaResult></div><script>function updateAreaFields(){var s=ashape.value;if(s=='square')areaFields.innerHTML='<label>Side:<br><input type=number id=a1 value=5 step=0.5></label>';else if(s=='rect')areaFields.innerHTML='<label>Length:<br><input type=number id=a1 value=5 step=0.5></label><label>Width:<br><input type=number id=a2 value=3 step=0.5></label>';else if(s=='circle')areaFields.innerHTML='<label>Radius:<br><input type=number id=a1 value=5 step=0.5></label>';else if(s=='triangle')areaFields.innerHTML='<label>Base:<br><input type=number id=a1 value=5 step=0.5></label><label>Height:<br><input type=number id=a2 value=4 step=0.5></label>';else if(s=='para')areaFields.innerHTML='<label>Base:<br><input type=number id=a1 value=5 step=0.5></label><label>Height:<br><input type=number id=a2 value=4 step=0.5></label>';else areaFields.innerHTML='<label>Base 1:<br><input type=number id=a1 value=5 step=0.5></label><label>Base 2:<br><input type=number id=a2 value=3 step=0.5></label><label>Height:<br><input type=number id=a3 value=4 step=0.5></label>';}function calcArea(){var s=ashape.value,a;if(s=='square')a=+a1.value**2;else if(s=='rect')a=+a1.value*+a2.value;else if(s=='circle')a=Math.PI*+a1.value**2;else if(s=='triangle')a=0.5*+a1.value*+a2.value;else if(s=='para')a=+a1.value*+a2.value;else a=0.5*(+a1.value+ +a2.value)*+a3.value;var n=s.charAt(0).toUpperCase()+s.slice(1);areaResult.innerHTML='<div style=background:#f0f9ff;padding:16px;border-radius:8px;margin-top:12px;><b>Area of '+n+'</b><hr><div style=font-size:36px;font-weight:700;color:#2563eb;text-align:center;>'+a.toFixed(2)+'</div><div style=text-align:center;color:#6b7280;>square units</div></div>';}</script>"
  }
}
