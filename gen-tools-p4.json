{
  "word-counter": {
    "title": "Word Counter & Character Count",
    "desc": "Count words, characters, sentences, paragraphs, and reading time in any text. Free online word counter for writers, students, and SEO.",
    "form": "<div style=display:grid;gap:8px;><label>Paste or type your text:<br><textarea id=wcText rows=6 style=width:100%;font-family:monospace;font-size:14px;>This is a sample text to count words, characters, and reading time.</textarea></label></div><button onclick=countWords()>Count</button><div id=wcResult></div><script>function countWords(){var t=wcText.value;var chars=t.length;var words=t.trim()?t.trim().split(/\\s+/).length:0;var sent=t.split(/[.!?]+/).filter(function(s){return s.trim().length>0}).length;var wordsPerMin=200;var readMin=Math.ceil(words/wordsPerMin);wcResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>Text Stats</b><hr><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;text-align:center;><div style=background:#dbeafe;padding:12px;border-radius:8px;><div style=font-size:32px;font-weight:700;color:#2563eb;>'+words+'</div><div>Words</div></div><div style=background:#fce7f3;padding:12px;border-radius:8px;><div style=font-size:32px;font-weight:700;color:#db2777;>'+chars+'</div><div>Characters</div></div><div style=background:#fef3c7;padding:12px;border-radius:8px;><div style=font-size:32px;font-weight:700;color:#d97706;>'+sent+'</div><div>Sentences</div></div><div style=background:#f0fdf4;padding:12px;border-radius:8px;><div style=font-size:32px;font-weight:700;color:#059669;>'+readMin+' min</div><div>Reading Time</div></div></div></div>';}</script>"
  },
  "age-calculator": {
    "title": "Age Calculator (Exact Years/Months/Days)",
    "desc": "Calculate your exact age in years, months, days, hours, minutes, and seconds. Find out how old you are down to the second.",
    "form": "<div style=display:grid;gap:8px;><label>Date of Birth:<br><input type=date id=birthDate style=width:100%;></label></div><button onclick=calcExactAge()>Calculate Age</button><div id=ageResult></div><script>function calcExactAge(){var b=new Date(birthDate.value);if(isNaN(b.getTime())){ageResult.innerHTML='<div style=color:#dc2626;>Please select your birth date.</div>';return}var now=new Date();var diff=now-b;var ms=diff%1000;var sec=Math.floor(diff/1000)%60;var min=Math.floor(diff/60000)%60;var hr=Math.floor(diff/3600000)%24;var days=Math.floor(diff/86400000);var yrs=now.getFullYear()-b.getFullYear();var m=now.getMonth()-b.getMonth();if(m<0||(m===0&&now.getDate()<b.getDate()))yrs--;if(m<0)m+=12;var d=now.getDate()-b.getDate();if(d<0){var pm=new Date(now.getFullYear(),now.getMonth(),0);d+=pm.getDate();m--}ageResult.innerHTML='<div style=background:#f0f0ff;padding:16px;border-radius:8px;margin-top:12px;text-align:center;><b>Your Exact Age</b><hr><div style=font-size:36px;font-weight:700;color:#7c3aed;>'+yrs+' years '+m+' months</div><div style=font-size:18px;color:#2563eb;>'+d+' days</div><hr><div style=color:#6b7280;font-size:14px;>'+days+' total days<br>'+hr+'h '+min+'m '+sec+'.'+ms+'s</div></div>';}</script>"
  },
  "tip-calculator": {
    "title": "Tip Calculator & Bill Splitter",
    "desc": "Calculate the tip amount and split bills between multiple people. Choose your tip percentage and see exactly what each person pays.",
    "form": "<div style=display:grid;gap:8px;><label>Bill Amount ($):<br><input type=number id=tbill value=85.5 step=0.5 style=width:100%;></label><label>Tip (%):<br><input type=range id=tpct min=5 max=30 value=15 oninput=updTip() style=width:100%;> <span id=tpctVal>15%</span></label><label>Split Between:<br><input type=number id=tsplit value=2 min=1 max=20 style=width:100%;></label></div><button onclick=calcTip()>Calculate</button><div id=tipResult></div><script>function updTip(){tpctVal.textContent=tpct.value+'%';}function calcTip(){var bill=+tbill.value,pct=+tpct.value/100,split=+tsplit.value;var tip=bill*pct,total=bill+tip,perPerson=total/split;tipResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>Bill Breakdown</b><hr><div>Bill: $'+bill.toFixed(2)+'</div><div>Tip ('+tpct.value+'%): $'+tip.toFixed(2)+'</div><hr><div style=font-size:20px;font-weight:600;color:#2563eb;>Total: $'+total.toFixed(2)+'</div><div>Per Person: <b>$'+perPerson.toFixed(2)+'</b></div></div>';}</script>"
  },
  "bmi-calculator": {
    "title": "BMI Calculator (Body Mass Index)",
    "desc": "Calculate your Body Mass Index and see your weight category. BMI chart, healthy weight range, and health risk information included.",
    "form": "<div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Weight (kg):<br><input type=number id=bmiw value=75 step=0.5></label><label>Height (cm):<br><input type=number id=bmih value=175 step=0.5></label></div><button onclick=calcBMI()>Calculate BMI</button><div id=bmiResult></div><script>function calcBMI(){var w=+bmiw.value,h=+bmih.value/100;if(h<=0){bmiResult.innerHTML='<div style=color:#dc2626;>Enter valid height.</div>';return}var bmi=w/(h*h);var cat=bmi<18.5?'Underweight':bmi<25?'Normal':bmi<30?'Overweight':bmi<35?'Obese Class I':bmi<40?'Obese Class II':'Obese Class III';var color=bmi<18.5?'#d97706':bmi<25?'#059669':bmi<30?'#d97706':'#dc2626';bmiResult.innerHTML='<div style=background:#f0fdf4;padding:16px;border-radius:8px;margin-top:12px;text-align:center;><b>Your BMI</b><hr><div style=font-size:48px;font-weight:700;color:'+color+';>'+bmi.toFixed(1)+'</div><div style=font-size:18px;color:#6b7280;>'+cat+'</div></div>';}</script>"
  },
  "sleep-calculator": {
    "title": "Sleep Calculator (Bedtime & Wake-up)",
    "desc": "Find the best time to go to bed based on 90-minute sleep cycles. Wake up refreshed between REM cycles at the optimal time.",
    "form": "<div style=display:grid;gap:8px;><label>I want to wake up at:<br><input type=time id=wakeTime value='07:00' style=width:100%;font-size:18px;></label><p style=color:#6b7280;font-size:13px;>Sleep cycles are ~90 min. Aim for 5-6 cycles (7.5-9 hrs).</p></div><button onclick=calcSleep()>Calculate Bedtimes</button><div id=sleepResult></div><script>function calcSleep(){var wt=wakeTime.value.split(':');var wh=+wt[0],wm=+wt[1];var wakeMin=wh*60+wm;var r='';for(var c=6;c>=4;c--){var bedMin=wakeMin-c*90;if(bedMin<0)bedMin+=1440;var bh=Math.floor(bedMin/60),bm=bedMin%60;var ap=bh>=12?'PM':'AM';if(bh>12)bh-=12;if(bh===0)bh=12;r+='<div style=background:';if(c===5)r+='#dbeafe';else if(c===6)r+='#f0fdf4';else r+='#f8fafc';r+=';padding:10px;border-radius:6px;margin:4px 0;><b>'+(bh<10?'0':'')+bh+':'+(bm<10?'0':'')+bm+' '+ap+'</b> &mdash; '+c+' cycles ('+(c*90/60).toFixed(0)+'.5 hrs)</div>'}sleepResult.innerHTML='<div style=margin-top:12px;><b>Best Bedtimes for '+wh.toString().padStart(2,'0')+':'+wm.toString().padStart(2,'0')+' wake-up</b><hr>'+r+'<div style=margin-top:8px;padding:8px;background:#fef3c7;border-radius:4px;font-size:13px;>Try the 5-cycle option for best balance.</div></div>';}</script>"
  },
  "color-picker": {
    "title": "Color Picker & HEX Converter",
    "desc": "Pick colors visually, get HEX, RGB, HSL codes. Perfect for web design, graphic design, and choosing color schemes for your projects.",
    "form": "<div style=text-align:center;><input type=color id=colorPicker value='#2563eb' onchange=updColor() style=width:80px;height:60px;border:none;cursor:pointer;><div id=colorPreview style=width:100%;height:80px;border-radius:8px;margin:8px 0;background:#2563eb;></div><label>HEX:<br><input type=text id=hexVal value='#2563eb' readonly style=width:100%;font-family:monospace;></label></div><button onclick=copyHex()>Copy HEX</button><div id=cpResult></div><script>function updColor(){var c=colorPicker.value;colorPreview.style.background=c;hexVal.value=c;}function copyHex(){navigator.clipboard.writeText(hexVal.value);cpResult.innerHTML='<div style=color:#059669;>Copied: '+hexVal.value+'</div>';setTimeout(function(){cpResult.innerHTML=''},2000);}</script>"
  },
  "timer": {
    "title": "Online Timer & Countdown",
    "desc": "A simple countdown timer with alarm. Set hours, minutes, and seconds for cooking, workouts, studying, or any timed activity.",
    "form": "<div style=text-align:center;><div style=display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;max-width:300px;margin:0 auto;><label>Hours:<br><input type=number id=tmH value=0 min=0 max=23 style=width:100%;text-align:center;></label><label>Minutes:<br><input type=number id=tmM value=5 min=0 max=59 style=width:100%;text-align:center;></label><label>Seconds:<br><input type=number id=tmS value=0 min=0 max=59 style=width:100%;text-align:center;></label></div><div id=timerDisplay style=font-size:64px;font-weight:700;font-family:monospace;color:#2563eb;margin:16px 0;>00:05:00</div><div style=display:flex;gap:8px;justify-content:center;flex-wrap:wrap;><button onclick=startTimer() style=padding:8px 24px;border:none;background:#059669;color:white;border-radius:8px;cursor:pointer;>Start</button><button onclick=pauseTimer() style=padding:8px 24px;border:none;background:#6b7280;color:white;border-radius:8px;cursor:pointer;>Pause</button><button onclick=resetTimer() style=padding:8px 24px;border:none;background:#dc2626;color:white;border-radius:8px;cursor:pointer;>Reset</button></div></div><script>var timerInt=null,totSec=300,remaining=300,paused=false;function updTimer(){var h=Math.floor(remaining/3600),m=Math.floor((remaining%3600)/60),s=remaining%60;timerDisplay.textContent=(h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s;}function startTimer(){var h=+tmH.value,m=+tmM.value,s=+tmS.value;if(!timerInt)totSec=h*3600+m*60+s;if(totSec<=0)return;remaining=totSec;paused=false;updTimer();if(timerInt)return;timerInt=setInterval(function(){if(!paused){remaining--;updTimer();if(remaining<=0){clearInterval(timerInt);timerInt=null;timerDisplay.textContent='00:00:00';alert('Time is up!');}}},1000);}function pauseTimer(){paused=!paused;}function resetTimer(){clearInterval(timerInt);timerInt=null;remaining=totSec;paused=false;updTimer();}</script>"
  }
}
