{
  "pnl-calculator": {
    "title": "Profit & Loss Statement Calculator",
    "desc": "Calculate your business profit and loss with a simple income statement. Track revenue, cost of goods sold, operating expenses, and net profit.",
    "form": "<div style=display:grid;grid-template-columns:1fr 1fr;gap:12px;><label>Revenue ($):<br><input type=number id=rev step=100 value=50000></label><label>COGS ($):<br><input type=number id=cogs step=100 value=20000></label><label>OpEx ($):<br><input type=number id=opex step=100 value=15000></label><label>Tax Rate (%):<br><input type=number id=taxr step=0.1 value=21></label></div><button onclick=calcPL()>Calculate P&amp;L</button><div id=plResult></div><script>function calcPL(){const r=+rev.value,c=+cogs.value,o=+opex.value,t=+taxr.value/100;const gp=r-c,op=gp-o,np=op*(1-t);plResult.innerHTML='<div style=background:#f0fdf4;padding:16px;border-radius:8px;><b>P&amp;L Statement</b><hr><div>Revenue: $'+r.toLocaleString()+'</div><div>COGS: -$'+c.toLocaleString()+'</div><div style=font-weight:600;color:#2563eb;>Gross Profit: $'+gp.toLocaleString()+' ('+(r>0?(gp/r*100).toFixed(1):0)+'%)</div><div>OpEx: -$'+o.toLocaleString()+'</div><div style=font-weight:600;>Operating Income: $'+op.toLocaleString()+'</div><div>Tax: $'+(op*t).toFixed(0)+'</div><div style=font-weight:600;color:#059669;font-size:18px;>Net Profit: $'+np.toFixed(0)+'</div></div>';}</script>"
  },
  "invoice-generator": {
    "title": "Simple Invoice Generator",
    "desc": "Create professional invoices instantly. Add line items, calculate totals, and generate a printable invoice for your freelance clients.",
    "form": "<div style=display:grid;gap:8px;><label>Client Name:<br><input type=text id=client value='ABC Corp' style=width:100%;></label><label>Item 1:<br><input type=text id=item1 value='Web Design' style=width:100%;></label><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Qty:<br><input type=number id=qty1 value=1 min=1></label><label>Rate ($):<br><input type=number id=rate1 value=500 step=10></label></div><label>Item 2:<br><input type=text id=item2 value='Hosting Setup' style=width:100%;></label><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Qty:<br><input type=number id=qty2 value=1 min=1></label><label>Rate ($):<br><input type=number id=rate2 value=150 step=10></label></div><label>Tax (%):<br><input type=number id=tax value=0 step=0.1></label></div><button onclick=genInvoice()>Generate Invoice</button><div id=invResult></div><script>function genInvoice(){const c=client.value,i1=item1.value,i2=item2.value,q1=+qty1.value,q2=+qty2.value,r1=+rate1.value,r2=+rate2.value,tx=+tax.value/100;const s1=r1*r1?q1:0,s2=r2*r2?q2:0,st=s1+s2,t=st*tx,tt=st+t;invResult.innerHTML='<div style=margin-top:12px;background:white;border:2px solid #e5e7eb;padding:20px;border-radius:8px;font-family:monospace;><h3 style=margin:0 0 8px;>INVOICE</h3><div style=border-bottom:1px solid #ddd;padding-bottom:8px;margin-bottom:8px;>To: <b>'+c+'</b></div><table style=width:100%;border-collapse:collapse;><tr style=border-bottom:1px solid #eee;><th style=text-align:left;padding:4px;>Item</th><th style=text-align:right;padding:4px;>Qty</th><th style=text-align:right;padding:4px;>Rate</th><th style=text-align:right;padding:4px;>Total</th></tr>'+(r1?'<tr><td>'+i1+'</td><td style=text-align:right;>'+q1+'</td><td style=text-align:right;>$'+r1+'</td><td style=text-align:right;>$'+s1+'</td></tr>':'')+(r2?'<tr><td>'+i2+'</td><td style=text-align:right;>'+q2+'</td><td style=text-align:right;>$'+r2+'</td><td style=text-align:right;>$'+s2+'</td></tr>':'')+'</table><hr><div><b>Subtotal: $'+st.toFixed(2)+'</b></div><div>Tax: $'+t.toFixed(2)+'</div><div style=font-size:18px;font-weight:600;color:#059669;>Total Due: $'+tt.toFixed(2)+'</div></div>';}</script>"
  },
  "employee-cost": {
    "title": "Employee Cost Calculator",
    "desc": "Calculate the true cost of an employee including salary, payroll taxes, benefits, equipment, and overhead for your business.",
    "form": "<div style=display:grid;gap:8px;><label>Base Salary ($/yr):<br><input type=number id=salary step=5000 value=50000 style=width:100%;></label><div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Benefits (%):<br><input type=number id=benefits value=20 step=1></label><label>Payroll Tax (%):<br><input type=number id=paytax value=7.65 step=0.1></label></div><label>Equipment/Setup ($):<br><input type=number id=equipment value=2000 step=500 style=width:100%;></label></div><button onclick=calcEmpCost()>Calculate Total Cost</button><div id=empResult></div><script>function calcEmpCost(){const s=+salary.value,b=+benefits.value/100,pt=+paytax.value/100,eq=+equipment.value;const bc=s*b,ptc=s*pt,tc=s+bc+ptc+eq;empResult.innerHTML='<div style=background:#f8fafc;padding:16px;border-radius:8px;margin-top:12px;><b>Employee Cost Breakdown</b><hr><div>Base Salary: $'+s.toLocaleString()+'</div><div>Benefits ('+(b*100)+'%): $'+bc.toFixed(0)+'</div><div>Payroll Tax ('+(pt*100)+'%): $'+ptc.toFixed(0)+'</div><div>Equipment: $'+eq.toLocaleString()+'</div><hr><div style=font-weight:600;font-size:18px;color:#2563eb;>Total Annual Cost: $'+tc.toFixed(0)+'</div><div style=color:#6b7280;>Monthly: $'+(tc/12).toFixed(0)+'</div></div>';}</script>"
  },
  "freelance-expense": {
    "title": "Freelance Expense Tracker",
    "desc": "Track and categorize your freelance business expenses. Calculate total deductions and see estimated tax savings for the year.",
    "form": "<div style=display:grid;grid-template-columns:1fr 1fr;gap:8px;><label>Software/Tools ($):<br><input type=number id=software step=10 value=600></label><label>Equipment ($):<br><input type=number id=equip step=100 value=1200></label><label>Home Office ($):<br><input type=number id=office step=50 value=800></label><label>Travel ($):<br><input type=number id=travel step=50 value=400></label><label>Internet/Phone ($):<br><input type=number id=utils step=10 value=600></label><label>Marketing ($):<br><input type=number id=marketing step=50 value=500></label><label>Est. Income ($):<br><input type=number id=income step=1000 value=60000></label><label>Tax Bracket (%):<br><input type=number id=tbracket step=1 value=22></label></div><button onclick=calcExpenses()>Calculate</button><div id=expResult></div><script>function calcExpenses(){const s=+software.value,e=+equip.value,o=+office.value,t=+travel.value,u=+utils.value,m=+marketing.value,inc=+income.value,tb=+tbracket.value/100;const total=s+e+o+t+u+m,savings=total*tb,taxable=inc-total>0?inc-total:0;expResult.innerHTML='<div style=background:#f0f9ff;padding:16px;border-radius:8px;margin-top:12px;><b>Expense Summary</b><hr><div>Software: $'+s.toLocaleString()+'</div><div>Equipment: $'+e.toLocaleString()+'</div><div>Home Office: $'+o.toLocaleString()+'</div><div>Travel: $'+t.toLocaleString()+'</div><div>Internet: $'+u.toLocaleString()+'</div><div>Marketing: $'+m.toLocaleString()+'</div><hr><div style=font-weight:600;font-size:18px;color:#2563eb;>Total Deductions: $'+total.toLocaleString()+'</div><div style=color:#059669;>Est. Tax Savings: $'+savings.toFixed(0)+'</div><div>Taxable Income: $'+taxable.toFixed(0)+'</div></div>';}</script>"
  }
}
